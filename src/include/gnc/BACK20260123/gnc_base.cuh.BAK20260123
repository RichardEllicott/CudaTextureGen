    }

    void _instance_test_2() {
        printf("_instance_test_2()...\n");

        for (auto *arr : get_all_of_type2<RefDeviceArrayFloat2D>()) {
            printf(" arr->instantiate_if_null()...\n");
            arr->instantiate_if_null();
        }
    }

    int _return_int_test(int v) {
